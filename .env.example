# Supabase project settings (Settings > API in the Supabase dashboard)
SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Server-only — never exposed to the browser bundle. Used for admin operations
# (account deletion, rate limiting) and bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# Same values, exposed to the client bundle by Vite (must start with VITE_)
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Server-only Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY="your-gemini-api-key"

# Server-only Resend API key (https://resend.com/api-keys), used by the Output
# node's "Send as email" action. Optional — email sending just errors clearly
# if unset, everything else still works.
RESEND_API_KEY="your-resend-api-key"
# Optional. Defaults to Resend's sandbox sender, which works without a
# verified domain. Set this once you've verified your own sending domain.
RESEND_FROM_EMAIL="Skein <onboarding@resend.dev>"
